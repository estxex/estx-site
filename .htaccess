RewriteEngine On

# Force HTTPS — the site was reachable over plain HTTP without redirect
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host: www -> apex (matches the canonical tag in index.html)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Browsers request /favicon.ico directly; the icon lives in brand_assets
RewriteRule ^favicon\.ico$ /brand_assets/favicon.png [L]
