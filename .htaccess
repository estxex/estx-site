RewriteEngine On

# Force HTTPS — the site was reachable over plain HTTP without redirect
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host: www -> apex (matches the canonical tag in index.html)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Browsers request /favicon.ico directly; the icon lives in brand_assets
RewriteRule ^favicon\.ico$ /brand_assets/favicon.png [L]

# No Cache-Control was sent at all, so browsers cached HTML heuristically
# and served stale pages after deploys. HTML revalidates every visit
# (304 when unchanged); images/fonts cache for a week.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|svg|webp|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
